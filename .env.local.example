# ============================================
# Propertize Local Development Environment
# ============================================
# Copy this file to .env and update values

# PostgreSQL (Local)
DB_USERNAME=dbuser
DB_PASSWORD=dbpassword
DB_HOST=localhost
DB_PORT=5432
DB_NAME=propertize_db

# MongoDB (Docker - don't change unless you modify docker-compose.infra.yml)
MONGO_USERNAME=admin
MONGO_PASSWORD=mongo_secure_pass

# Redis (Docker - don't change unless you modify docker-compose.infra.yml)
REDIS_PASSWORD=redis_secure_pass

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production-min-256-bits

# Service-to-Service Authentication
SERVICE_API_KEY=dev-api-key-12345-change-in-production

# Mongo Express UI (Optional)
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=admin

# Application Environment
SPRING_PROFILES_ACTIVE=local
NODE_ENV=development
