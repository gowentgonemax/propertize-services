# ============================================
# Propertize Platform — Environment Variables
# Copy to .env: cp .env.example .env
# Then change ALL passwords before running
# ============================================

# ── Database ──────────────────────────────────
POSTGRES_DB=propertize_db
POSTGRES_USER=dbuser
POSTGRES_PASSWORD=CHANGE_ME_secure_db_password

# ── MongoDB ───────────────────────────────────
MONGO_USERNAME=admin
MONGO_PASSWORD=CHANGE_ME_secure_mongo_password
MONGO_DB=propertize_db

# ── Redis ─────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_secure_redis_password

# ── MinIO (S3-compatible storage) ─────────────
MINIO_ROOT_USER=propertize
MINIO_ROOT_PASSWORD=CHANGE_ME_secure_minio_password

# ── Service API Keys ─────────────────────────
GATEWAY_SERVICE_KEY=CHANGE_ME_gateway_secret
PROPERTIZE_SERVICE_KEY=CHANGE_ME_propertize_secret
EMPLOYECRAFT_SERVICE_KEY=CHANGE_ME_employecraft_secret
AUTH_SERVICE_API_KEY=CHANGE_ME_auth_service_secret

# ── JWT ───────────────────────────────────────
JWT_SECRET=CHANGE_ME_at_least_32_chars_random_string

# ── Mongo Express UI ─────────────────────────
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=CHANGE_ME

# ── Application ──────────────────────────────
SPRING_PROFILES_ACTIVE=local

# Mongo Express UI
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=admin_change_me

# Application
SPRING_PROFILES_ACTIVE=local

# Optional: Email Configuration
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password

# Optional: Cloud Storage
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1

# Optional: External APIs
# STRIPE_API_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
