# ============================================
# Environment Variables Template
# Copy to .env and fill in your values
# ============================================

# Database Credentials
POSTGRES_PASSWORD=propertize_secure_pass_change_me
MONGO_USERNAME=admin
MONGO_PASSWORD=mongo_secure_pass_change_me

# Redis
REDIS_PASSWORD=redis_secure_pass_change_me

# JWT Secret (use a long random string in production)
JWT_SECRET=your-secret-key-minimum-32-characters-long-change-in-production

# Mongo Express UI
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=admin_change_me

# Application
SPRING_PROFILES_ACTIVE=local

# Optional: Email Configuration
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password

# Optional: Cloud Storage
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1

# Optional: External APIs
# STRIPE_API_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
